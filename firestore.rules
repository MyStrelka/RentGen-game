rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: leaderboard
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required) - Telegram display name
    //   - score: number (required) - Throughput score
    //   - timestamp: timestamp (required) - When recorded
    //   - uid: string (optional) - User ID
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidScore(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 50 &&
             data.score is number && data.score >= 0 &&
             data.timestamp is timestamp;
    }

    match /leaderboard/{scoreId} {
      // Allow anyone to read the leaderboard (public scores)
      allow read: if true;
      
      // Allow creating a score if it's valid
      // Note: In this simple game, we might not require auth for simplicity,
      // but let's follow the user's request for Firebase.
      allow create: if isValidScore(request.resource.data);
      
      // No updates or deletes allowed for scores to prevent tampering
      allow update, delete: if false;
    }
  }
}
